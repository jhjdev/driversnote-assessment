{
  "name": "driversnote-assessment",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "app",
    "api"
  ],
  "scripts": {
    "app": "npm run start --workspace=app",
    "app:android": "npm run android --workspace=app",
    "app:ios": "npm run ios --workspace=app",
    "api": "npm run dev --workspace=api",
    "api:build": "npm run build --workspace=api",
    "api:start": "npm run start --workspace=api",
    "test": "npm run test --workspaces",
    "lint": "npm run lint --workspaces",
    "lint:fix": "npm run lint:fix --workspaces"
  },
  "description": "Driversnote assessment monorepo containing React Native app and Fastify API",
  "overrides": {
    "react-native-worklets": "0.7.4",
    "postcss": "^8.5.10",
    "uuid": "^14.0.0",
    "@tootallnate/once": "^3.0.1"
  }
}
